# e-Stat API アプリケーションID
# https://www.e-stat.go.jp/api/ から取得
ESTAT_APP_ID=

# 使う統計表のstatsDataId（任意・未設定なら令和2年国勢調査基準の複数年表を使用）
# 例: e-Statで表を開いたときのURLやAPIタブに表示されるIDをコピーする
ESTAT_STATS_ID_POPULATION=

# 合計特殊出生率のstatsDataId（任意・未設定なら人口動態統計の代表表を使用）
ESTAT_STATS_ID_BIRTHRATE=

# 離婚率のstatsDataId（任意・未設定なら人口動態統計の代表表を使用）
ESTAT_STATS_ID_DIVORCE=

# 年少人口割合(15歳未満人口割合)のstatsDataId（任意・未設定なら人口推計の代表表を使用）
ESTAT_STATS_ID_CHILDREN_RATIO=

# 高齢化率(65歳以上人口割合)のstatsDataId（任意・未設定なら人口推計の代表表を使用）
ESTAT_STATS_ID_AGING_RATIO=

# サイトの本番URL（OGP・sitemap生成に使用）
NEXT_PUBLIC_SITE_URL=https://data-mikke-lab.vercel.app

# お問い合わせページに表示するメールアドレス
NEXT_PUBLIC_CONTACT_EMAIL=

# 運営者情報・プライバシーポリシーに表示する氏名/屋号
NEXT_PUBLIC_OPERATOR_NAME=

# Google AdSenseの発行者ID（審査申請の前にサイトへ貼る確認用スクリプト・ads.txt生成に使用）
# 例: ca-pub-1234567890123456（現在コード側のデフォルトに ca-pub-4630812027939211 を設定済み。
# 別サイトで使い回す場合はここで上書きする）
NEXT_PUBLIC_ADSENSE_CLIENT=
